---
import type { Organizer } from "../../types/event";

interface FooterLink {
  label: string;
  href: string;
}

interface Props {
  organizers: Organizer[];
  credit: string;
  links: FooterLink[];
}

const { organizers, credit, links } = Astro.props as Props;
---

<footer class="border-t border-white/10 bg-darker/70">
  <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-10 md:grid-cols-3 md:px-6">
    <div>
      <h3 class="mb-3 text-2xl uppercase text-white">Partners</h3>
      <ul class="space-y-2 text-sm text-light/90">
        {organizers.map((org) => (
          <li>{org.name}</li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="mb-3 text-2xl uppercase text-white">Attribution</h3>
      <p class="text-sm text-light/90">{credit}</p>
      <a href="https://hackclub.com" class="mt-4 inline-flex" aria-label="Hack Club homepage">
        <img
          src="https://assets.hackclub.com/flag-standalone.svg"
          alt="Hack Club"
          class="h-10 w-auto"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>

    <div>
      <h3 class="mb-3 text-2xl uppercase text-white">Links</h3>
      <ul class="space-y-2 text-sm text-light/90">
        {links.map((link) => (
          <li>
            <a href={link.href} class="underline decoration-dotted underline-offset-4 hover:text-warning">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
