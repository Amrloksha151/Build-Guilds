---
import Card from "../ui/Card.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import type { FAQItem } from "../../types/event";

interface Props {
  id?: string;
  faq: FAQItem[];
  title: string;
  subtitle: string;
}

const { id = "faq", faq, title, subtitle } = Astro.props as Props;
---

{faq.length > 0 && (
  <section id={id} class="px-4 py-14 md:px-6 md:py-20">
    <div class="mx-auto w-full max-w-6xl">
      <SectionHeading title={title} subtitle={subtitle} />

      <div class="space-y-4">
        {faq.map((item) => (
          <Card>
            <details class="group">
              <summary class="cursor-pointer list-none pr-8 text-xl font-bold uppercase text-white">
                {item.question}
              </summary>
              <p class="mt-3 text-light/90">{item.answer}</p>
            </details>
          </Card>
        ))}
      </div>
    </div>
  </section>
)}
