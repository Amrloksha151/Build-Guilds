---
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  id?: string;
  registrationOpen: boolean;
  registrationUrl: string | null;
  title: string;
  description: string;
  liveTitle: string;
  liveDescription: string;
  liveButtonLabel: string;
  invalidUrlDescription: string;
  notifyTitle: string;
  notifyDescription: string;
  buttonLabel: string;
  placeholder: string;
}

const {
  id = "signup",
  registrationOpen,
  registrationUrl,
  title,
  description,
  liveTitle,
  liveDescription,
  liveButtonLabel,
  invalidUrlDescription,
  notifyTitle,
  notifyDescription,
  buttonLabel,
  placeholder
} = Astro.props as Props;

const hasValidRegistrationUrl = (() => {
  if (!registrationUrl) {
    return false;
  }

  try {
    const parsed = new URL(registrationUrl);
    return parsed.protocol === "https:";
  } catch {
    return false;
  }
})();
---

<section id={id} class="px-4 py-14 md:px-6 md:py-20">
  <div class="mx-auto w-full max-w-6xl">
    <SectionHeading title={title} subtitle={description} />

    <Card className="max-w-2xl">
      {registrationOpen && hasValidRegistrationUrl ? (
        <div class="space-y-4">
          <h3 class="text-2xl uppercase text-white">{liveTitle}</h3>
          <p class="text-bp-muted">{liveDescription}</p>
          <Button href={registrationUrl!} size="lg" target="_blank" rel="noopener noreferrer">
            {liveButtonLabel}
          </Button>
        </div>
      ) : registrationOpen ? (
        <div class="space-y-4">
          <h3 class="text-2xl uppercase text-white">{liveTitle}</h3>
          <p class="text-bp-muted">{invalidUrlDescription}</p>
        </div>
      ) : (
        <div class="space-y-4">
          <h3 class="text-2xl uppercase text-white">{notifyTitle}</h3>
          <p class="text-bp-muted">{notifyDescription}</p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <input
              type="email"
              placeholder={placeholder}
              class="w-full rounded-full border border-white/40 bg-[rgb(var(--bp-darker-rgb))] px-5 py-3 text-white placeholder:text-[rgb(var(--bp-light-rgb)/0.82)] focus:border-[rgb(var(--bp-warning-rgb))] focus:outline-none"
              aria-label="Email address"
            />
            <Button type="button" size="lg">{buttonLabel}</Button>
          </div>
          <p class="text-bp-subtle text-xs">Static marketing mode: connect this field to your preferred external form when ready.</p>
        </div>
      )}
    </Card>
  </div>
</section>
