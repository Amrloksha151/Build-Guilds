---
interface Props {
  src?: string | null;
  alt?: string;
}

const { src, alt = "Gharbiya STEM Robo Club" } = Astro.props as Props;
---

<div class="flex h-20 w-full items-center justify-center rounded-xl border border-white/10 bg-darker/70 px-4">
  {src ? (
    <img src={src} alt={alt} class="h-12 w-auto object-contain" loading="lazy" decoding="async" />
  ) : (
    <span class="text-center text-sm font-bold text-white/85">{alt}</span>
  )}
</div>
