---
interface Props {
  href?: string;
  variant?: "primary" | "outline";
  size?: "md" | "lg";
  className?: string;
  type?: "button" | "submit";
  target?: string;
  rel?: string;
}

const { href, variant = "primary", size = "md", className = "", type = "button", target, rel } =
  Astro.props as Props;

const baseClass =
  "inline-flex items-center justify-center rounded-full border font-sans text-sm font-bold tracking-wide transition hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--bp-warning-rgb))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--bp-dark-rgb))]";
const variantClass =
  variant === "outline"
    ? "border-white bg-transparent text-white"
    : "border-white bg-white text-[rgb(var(--bp-darker-rgb))] shadow-sm";
const sizeClass = size === "lg" ? "px-6 py-3 text-base" : "px-5 py-2.5";
const classes = `${baseClass} ${variantClass} ${sizeClass} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={rel}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
