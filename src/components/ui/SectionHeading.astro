---
interface Props {
  title: string;
  eyebrow?: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, eyebrow, subtitle, align = "left" } = Astro.props as Props;
const alignment = align === "center" ? "text-center items-center" : "text-left items-start";
---

<header class={`mb-8 flex flex-col gap-3 ${alignment}`}>
  {eyebrow && <p class="font-sans text-sm font-bold uppercase tracking-[0.12em] text-[rgb(var(--bp-warning-rgb))]">{eyebrow}</p>}
  <h2 class="text-4xl uppercase leading-tight text-white md:text-5xl">{title}</h2>
  {subtitle && <p class="text-bp-muted max-w-3xl text-base md:text-lg">{subtitle}</p>}
</header>
