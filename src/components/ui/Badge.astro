---
interface Props {
  label: string;
  variant?: "warning" | "success" | "danger" | "neutral";
}

const { label, variant = "neutral" } = Astro.props as Props;

const classesByVariant: Record<string, string> = {
  warning: "border-[rgb(var(--bp-warning-rgb)/0.8)] bg-[rgb(var(--bp-warning-rgb)/0.18)] text-[rgb(var(--bp-warning-rgb))]",
  success: "border-[rgb(var(--bp-success-rgb)/0.6)] bg-[rgb(var(--bp-success-rgb)/0.2)] text-[rgb(var(--bp-success-rgb))]",
  danger: "border-[rgb(var(--bp-danger-rgb)/0.6)] bg-[rgb(var(--bp-danger-rgb)/0.2)] text-[rgb(var(--bp-danger-rgb))]",
  neutral: "border-white/30 bg-white/10 text-white"
};
---

<span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-[0.08em] ${classesByVariant[variant]}`}>
  {label}
</span>
